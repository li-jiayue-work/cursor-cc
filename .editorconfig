root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{py,go,ts,tsx,js,jsx,rs,java}]
indent_style = space
indent_size = 4

[*.{yml,yaml,json,css,html}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
